---
import NewsletterForm from './NewsletterForm.astro';
import type { Hero } from '../../types/content';

interface Props {
  hero: Hero;
}

const { hero } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <h1 id="hero-title" class="hero__title">{hero.title}</h1>
  <p class="hero__description">{hero.description}</p>
  <NewsletterForm newsletter={hero.newsletter} />
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-md);
  }

  .hero__title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .hero__description {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 540px;
    line-height: 1.55;
  }
</style>
