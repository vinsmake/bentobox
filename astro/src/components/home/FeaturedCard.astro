---
import type { FeaturedItem } from '../../types/content';

interface Props {
  item: FeaturedItem;
}

const { item } = Astro.props;
---

<article class:list={['feat', `feat--${item.layout}`]}>
  <div class="feat__content">
    <h3 class="feat__title">{item.title}</h3>
    <p class="feat__description">{item.description}</p>
    <a class="feat__link" href={item.link}>
      Read More
      <svg
        viewBox="0 0 24 24"
        width="14"
        height="14"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M9 6l6 6-6 6" />
      </svg>
    </a>
  </div>
  <div class="feat__media" aria-hidden="true">
    <img src={item.image} alt="" loading="lazy" />
  </div>
</article>

<style>
  .feat {
    position: relative;
    display: flex;
    background: var(--color-card);
    color: var(--color-text-on-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    height: 100%;
    min-height: 240px;
  }

  .feat--tall {
    flex-direction: column;
  }

  .feat--wide {
    flex-direction: row;
    align-items: stretch;
  }

  .feat__content {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
    min-width: 0;
  }

  .feat__title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .feat__description {
    font-size: 0.9rem;
    color: var(--color-text-on-card-muted);
    line-height: 1.5;
    margin-bottom: auto;
  }

  .feat__link {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.05rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-on-card);
    border: 1px solid var(--color-border-light);
    border-radius: 999px;
    transition: background-color 0.2s ease;
    margin-top: 0.5rem;
  }

  .feat__link:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }

  .feat__media {
    flex-shrink: 0;
  }

  .feat--tall .feat__media {
    width: 100%;
    flex: 1;
    min-height: 220px;
  }

  .feat--wide .feat__media {
    width: 45%;
    min-height: 100%;
  }

  .feat__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 720px) {
    .feat--wide {
      flex-direction: column;
    }

    .feat--wide .feat__media {
      width: 100%;
      min-height: 220px;
    }
  }
</style>
