---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import FeaturedGrid from '../components/home/FeaturedGrid.astro';
import ArticlesSection from '../components/articles/ArticlesSection.astro';
import data from '../data/data.json';
import type { SiteData } from '../types/content';

const content = data as SiteData;
---

<BaseLayout title={`${content.site.name} — ${content.hero.title}`} description={content.hero.description}>
  <Header site={content.site} navigation={content.navigation} />

  <main>
    <FeaturedGrid hero={content.hero} items={content.featured} />
    <ArticlesSection section={content.articles} />
  </main>
</BaseLayout>
