---
import type { NavItem } from '../../types/content';

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<nav class="nav" aria-label="Primary">
  <ul class="nav__list">
    {
      items.map((item) => (
        <li class="nav__item">
          <a class="nav__link" href={item.href}>
            {item.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav__list {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 2.5vw, 2.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    transition: opacity 0.2s ease;
  }

  .nav__link:hover {
    opacity: 0.6;
  }

  @media (max-width: 720px) {
    .nav__list {
      justify-content: center;
    }
  }
</style>
