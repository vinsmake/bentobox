---
import AuthorBadge from './AuthorBadge.astro';
import CategoryTag from './CategoryTag.astro';
import type { Article } from '../../types/content';

interface Props {
  article: Article;
}

const { article } = Astro.props;
---

<article class="card">
  <a class="card__media" href={`#${article.id}`} aria-label={article.title}>
    <img src={article.image} alt={article.title} loading="lazy" />
  </a>
  <div class="card__body">
    <CategoryTag category={article.category} />
    <h3 class="card__title">
      <a href={`#${article.id}`}>{article.title}</a>
    </h3>
    <p class="card__description">{article.description}</p>
    <AuthorBadge author={article.author} date={article.date} />
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .card__media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 16 / 11;
  }

  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card__media:hover img {
    transform: scale(1.03);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .card__title {
    font-size: clamp(1.15rem, 1.7vw, 1.5rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
  }

  .card__description {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }
</style>
